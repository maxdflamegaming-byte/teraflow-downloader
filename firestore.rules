rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: downloads
    // Document ID: auto-generated
    // Fields:
    //   - videoId: string (required) - TeraBox video ID
    //   - title: string (required) - Video title
    //   - thumbnail: string (optional) - Thumbnail URL
    //   - size: string (optional) - File size
    //   - quality: string (optional) - Selected quality
    //   - format: string (optional) - Selected format
    //   - downloadUrl: string (optional) - Direct download URL
    //   - downloadedAt: timestamp (required) - Download time
    //   - uid: string (required) - User UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDownload(data) {
      return hasRequiredFields(['videoId', 'title', 'downloadedAt', 'uid']) &&
             hasOnlyAllowedFields(['videoId', 'title', 'thumbnail', 'size', 'quality', 'format', 'downloadUrl', 'downloadedAt', 'uid']) &&
             data.videoId is string && data.videoId.size() > 0 && data.videoId.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             (!('thumbnail' in data) || (data.thumbnail is string && data.thumbnail.size() < 2000)) &&
             (!('size' in data) || (data.size is string && data.size.size() < 50)) &&
             (!('quality' in data) || (data.quality is string && data.quality.size() < 20)) &&
             (!('format' in data) || (data.format is string && data.format.size() < 10)) &&
             (!('downloadUrl' in data) || (data.downloadUrl is string && data.downloadUrl.size() < 2000)) &&
             data.downloadedAt is timestamp &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /downloads/{downloadId} {
      // Users can only read their own downloads
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      
      // Users can create their own download records
      allow create: if isAuthenticated() && isValidDownload(request.resource.data);
      
      // Users can delete their own records
      allow delete: if isAuthenticated() && isDocOwner();

      // Downloads are immutable
      allow update: if false;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
